{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MarksmanMate (dev API)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--web-port=7357",
        "--dart-define-from-file=config/dev.env.json"
      ]
    },
    {
      "name": "MarksmanMate (production API)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--dart-define-from-file=config/prod.env.json"
      ]
    },
    {
      "name": "MarksmanMate (Windows, dev API)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "windows",
        "--dart-define-from-file=config/dev.env.json"
      ]
    }
  ]
}
